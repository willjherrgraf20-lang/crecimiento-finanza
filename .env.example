# ── Supabase PostgreSQL ──────────────────────────────────────────────────────
# Puerto 6543 (PgBouncer pooler) para la app
DATABASE_URL="postgresql://postgres.[ref]:[pass]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
# Puerto 5432 (direct) para prisma migrate
DIRECT_URL="postgresql://postgres.[ref]:[pass]@aws-0-[region].supabase.com:5432/postgres"

# ── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET="cambiar-por-secreto-seguro-de-32-caracteres-minimo"

# ── Gmail OAuth2 (Google Cloud Console) ──────────────────────────────────────
GOOGLE_CLIENT_ID="....apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-..."
GOOGLE_REDIRECT_URI="http://localhost:3000/api/email/callback"

# ── Seguridad ─────────────────────────────────────────────────────────────────
# 32 bytes en hex: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY="[64 caracteres hex]"
CRON_SECRET="cambiar-por-secreto-cron"
